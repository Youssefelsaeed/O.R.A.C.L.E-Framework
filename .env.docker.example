# Optional Docker runtime environment for O.R.A.C.L.E Framework.
# Do not place secrets in this file. Copy to .env.docker only for local overrides.

ORACLE_ASYNC_ASSURANCE=1
GHOSTTUNNEL_FAST_ACK=1
ORACLE_FAST_PIPELINE=1
VITE_ORACLE_API_BASE_URL=http://127.0.0.1:8000

# Runtime volumes are mounted from the host:
# ./reports -> /app/reports
# ./data -> /app/data
# ./models_candidate -> /app/models_candidate
# ./models_final -> /app/models_final:ro
