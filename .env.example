# ORACLE Final local configuration
PYTHONPATH=.
ORACLE_ASYNC_ASSURANCE=1
GHOSTTUNNEL_FAST_ACK=1
SERVICE_TIMING_LOG=0

# GUI
VITE_ORACLE_API_BASE_URL=http://127.0.0.1:8000

# Service ports
ORACLE_CORE_PORT=8000
QAUTHCORE_PORT=8001
ETHICQ_PORT=8002
CHRONOLEDGER_PORT=8003
GHOSTTUNNEL_PORT=8004
ORACLE_GUI_PORT=4173

# Evolution safety
EVOLUTION_MODE=candidate-only
EVOLUTION_DRY_RUN=true
EVOLUTION_AUTO_PROMOTE=false
EVOLUTION_USE_GAN=false

# Optional local dataset paths; datasets are not uploaded to GitHub
CSE_CIC_IDS2018_PATH=Workin with/CSE-CIC-IDS-2018
DOHBRW_PATH=Workin with/DohbrW
