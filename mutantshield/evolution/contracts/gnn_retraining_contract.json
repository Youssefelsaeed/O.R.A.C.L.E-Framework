{
  "contract_name": "gnn_retraining_contract",
  "contract_version": "1.0",
  "model_family": "GNN",
  "purpose": "Candidate-safe production-line GNN retraining gate for MutantShield Evolution Engine.",
  "required_graph_input_schema": {
    "required_columns": [
      "flow_id",
      "src_ip",
      "dst_ip",
      "timestamp",
      "label",
      "is_attack",
      "attack_family"
    ],
    "edge_features": "numeric MutantShield flow feature columns in documented feature order",
    "node_identity_mapping": [
      "src_ip",
      "dst_ip"
    ],
    "target_column": "is_attack",
    "label_column": "label"
  },
  "graph_construction_rules": {
    "nodes": "normalized host identities",
    "edges": "flows from src_ip to dst_ip",
    "edge_features": "numeric flow features",
    "temporal_order": "timestamp",
    "windowing": "chronological graph windows",
    "forbidden_methods": [
      "training from buffers without src/dst/timestamp",
      "synthetic graph reconstruction presented as real evidence",
      "mutating production GNN builder files"
    ]
  },
  "graph_split_rules": [
    "avoid temporal leakage",
    "prefer chronological train/validation/test split",
    "fit node mapping and scaler on training split only",
    "do not place identical flow_id in multiple splits"
  ],
  "allowed_candidate_output_directory": "models_candidate/<candidate_id>/GNN/",
  "required_output_artifacts": [
    "gnn_candidate.pth",
    "gnn_candidate_builder.pkl",
    "gnn_candidate_metadata.json",
    "gnn_training_report.json"
  ],
  "required_metadata_fields": [
    "candidate_id",
    "model_family",
    "contract_name",
    "contract_version",
    "created_at",
    "feature_order",
    "node_mapping",
    "graph_window_seconds",
    "split_strategy",
    "training_rows",
    "training_edges",
    "training_nodes",
    "source_datasets",
    "models_final_unchanged",
    "promotion_eligible"
  ],
  "forbidden_output_directories": [
    "models_final/",
    "Mutant_Sheild Module/mutantshield/src/FinalVersion/models_final/",
    "Mutant_Sheild Module/mutantshield/src/FinalVersion/models_final/GNN/",
    "Mutant_Sheild Module/mutantshield/src/FinalVersion/models_final/FusionEngine/",
    "Mutant_Sheild Module/mutantshield/src/FinalVersion/models_final/LSTM_Optimized/"
  ],
  "validation_gates_before_training": [
    "required graph columns present",
    "src_ip and dst_ip non-empty",
    "timestamp parseable",
    "numeric edge features available",
    "deterministic node mapping constructible",
    "temporal graph windows constructible",
    "candidate output path under models_candidate",
    "models_final hash snapshot recorded"
  ],
  "rollback_safety_requirements": [
    "candidate-only dry-run by default",
    "write blocked or failed report on graph construction failure",
    "never promote automatically",
    "never write models_final",
    "do not label inferred graph structure as real GNN retraining"
  ]
}
